{% liquid
  assign btn_pos = shop.metafields.app.nbl_config_v1.value.styles.actionButton['Button Position'] | downcase | default: 'left'
  if btn_pos != 'right'
    assign btn_pos = 'left'
  endif
%}

<script>
  window.NBL_v1 = window.NBL_v1 || {};

  NBL_v1.appConfig = {{ shop.metafields.app.nbl_config_v1.value | json }};

  NBL_v1.customer = {
    id:         {{ customer.id         | json }},
    email:      {{ customer.email      | json }},
    name:       {{ customer.name       | json }},
    first_name: {{ customer.first_name | json }},
    last_name:  {{ customer.last_name  | json }},
    config:     {{ customer.metafields.app.nbl_customer_v1.value | json }}
  };

  if (NBL_v1.customer && NBL_v1.customer.config && NBL_v1.customer.config.points) {
    NBL_v1.points = NBL_v1.customer.config.points || 0;
  }

  NBL_v1.routes = {
    account_url:  {{ routes.account_url  | json }},
    login_url:    {{ routes.login_url    | json }},
    logout_url:   {{ routes.logout_url   | json }},
    register_url: {{ routes.register_url | json }}
  };

  NBL_v1.liquidData = {
    isLoggedIn:     {{ customer | json | default: 'null' }} !== null,
    customerName:   {{ customer.name | json | default: '""' }},
    shopUrl:        {{ shop.url | json }},
    referralCode:   {{ customer.metafields.app.nbl_customer_v1.value.referralCode | json | default: '""' }},
    headerLabel:    {{ shop.metafields.app.nbl_config_v1.value.styles.header.Heading.Label | json | default: '"Welcome, [name]"' }},
    pointsLabel:    {{ shop.metafields.app.nbl_config_v1.value.styles.header.Points.Label  | json | default: '"[points] points"' }},
    buttonPosition: {{ btn_pos | json }}
  };

  NBL_v1.tab      = NBL_v1.tab      || {};
  NBL_v1.uiRender = NBL_v1.uiRender || {};

  (function loadWidget() {
    var appUrl = (window.NBL_v1.appConfig && window.NBL_v1.appConfig.appUrl) || '';
    if (!appUrl || document.getElementById('nbl-widget-css')) return;

    var cssUrl = "{{ 'ui.min.css' | asset_url }}";
    var jsUrl = "{{ 'ui.min.js' | asset_url }}";

    var preloadLink = document.createElement('link');
    preloadLink.rel  = 'preload';
    preloadLink.as   = 'style';
    {% comment %} preloadLink.href = cssUrl; {% endcomment %}
    preloadLink.href = appUrl + '/widget/ui.v3.css';
    document.head.appendChild(preloadLink);

    var styleLink = document.createElement('link');
    styleLink.id   = 'nbl-widget-css';
    styleLink.rel  = 'stylesheet';
    {% comment %} styleLink.href = cssUrl; {% endcomment %}
    styleLink.href = appUrl + '/widget/ui.v3.css';
    document.head.appendChild(styleLink);

    var scriptTag = document.createElement('script');
    {% comment %} scriptTag.src   = jsUrl; {% endcomment %}
    scriptTag.src   = appUrl + '/widget/ui.v3.js';
    scriptTag.async = true;
    document.head.appendChild(scriptTag);
  })();
</script>

{% schema %}
{
  "name": "NB Loyalty",
  "target": "body",
  "settings": []
}
{% endschema %}
