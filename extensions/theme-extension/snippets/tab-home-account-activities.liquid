<div class="nbl-home-tab-v1" data-tab="account-activities">
  <div class="nbl-home-tab-header-v1">
    <div class="nbl-hth-heading-v1">Your account activities</div>
    <button class="nbl-hth-toggle-btn-v1">Show</button>
  </div>
  <div class="nbl-home-tab-body-v1">
    <div class="nbl-haTa-wrapper-v1">
      <div class="nbl-haTa-head-v1">
        <div class="nbl-haTa-head-item-v1">Date</div>
        <div class="nbl-haTa-head-item-v1">Activity</div>
        <div class="nbl-haTa-head-item-v1">Points</div>
      </div>
      <div class="nbl-haTa-list-wrapper-v1">
        <div class="nbl-haTa-list-empty-v1">No account activities yet</div>
      </div>
    </div>
  </div>
</div>

<script>
  NBL_v1.tab.renderHomeAccountTransactionActivities = () => {
    const listWrapper = document.querySelector('.nbl-haTa-list-wrapper-v1');
    if (!listWrapper) return;

    const transactions = NBL_v1.customer.config.transactions || [];

    const emptyState = `<div class="nbl-haTa-list-empty-v1">No account activities yet</div>`;

    /* -------------------- Helpers -------------------- */

    const formatDate = (dateStr) =>
      new Date(dateStr).toLocaleDateString(undefined, {
        day: '2-digit',
        month: 'short',
        year: 'numeric',
      });

    const formatPoints = (points) => {
      if (points > 0) return `<span class="nbl-points-positive">+${points}</span>`;
      if (points < 0) return `<span class="nbl-points-negative">${points}</span>`;
      return `<span>${points}</span>`;
    };

    const formatStatus = (status) => {
      const map = {
        COMPLETED: 'Approved',
        PENDING: 'Pending',
        CANCELLED: 'Cancelled',
        REVERSED: 'Reversed',
      };
      return map[status] || status || '—';
    };

    /* -------------------- Template -------------------- */

    const buildItem = (t) => `
      <div class="nbl-haTa-list-v1" data-transaction-id="${t.id}">
        <div class="nbl-haTa-list-item-v1">${formatDate(t.createdAt)}</div>
        <div class="nbl-haTa-list-item-v1">${t.activity || t.reason || '—'}</div>
        <div class="nbl-haTa-list-item-v1">${formatPoints(t.points)}</div>
      </div>
    `;

    /* -------------------- Render -------------------- */

    listWrapper.innerHTML = transactions.length ? transactions.map(buildItem).join('') : emptyState;
  };

  /* -------------------- Event listeners -------------------- */

  NBL_v1.bus.on('dom:loaded', () => {
    NBL_v1.tab.renderHomeAccountTransactionActivities();
  });
</script>
