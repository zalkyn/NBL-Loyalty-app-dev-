{% render 'loyalty-notification-css' %}

<!-- OVERLAY -->
<div class="nbl-notify-overlay-v1"></div>

<!-- REWARD -->
<div class="nbl-notify-reward-container-v1 nbl-notify-base-v1">
  <span class="nbl-notify-reward-close-v1">✕</span>

  <div class="nbl-notify-reward-heading-v1">Success! Use this code at checkout</div>

  <div class="nbl-notify-reward-copy-wrapper-v1">
    <div class="nbl-notify-reward-code-v1"></div>
    <button class="nbl-notify-reward-copy-btn-v1">Copy</button>
  </div>
</div>

<!-- INFO -->
<div class="nbl-notify-info-container-v1 nbl-notify-base-v1">
  <span class="nbl-notify-info-close-v1">✕</span>

  <div class="nbl-notify-info-text-v1"></div>
  <div class="nbl-notify-info-error-v1"></div>

  <button class="nbl-notify-info-claim-btn-v1">Claim</button>
</div>

<script>
  window.NBL_v1 = window.NBL_v1 || {};

  /* =========================
       NOTIFY
  ========================= */
  NBL_v1.notify = (function () {
    const bus = NBL_v1.bus;
    const overlay = document.querySelector('.nbl-notify-overlay-v1');
    const rewardEl = document.querySelector('.nbl-notify-reward-container-v1');
    const rewardWrapper = rewardEl.querySelector('.nbl-notify-reward-copy-wrapper-v1');
    const infoEl = document.querySelector('.nbl-notify-info-container-v1');
    const infoText = infoEl.querySelector('.nbl-notify-info-text-v1');
    const infoError = infoEl.querySelector('.nbl-notify-info-error-v1');
    const claimBtn = infoEl.querySelector('.nbl-notify-info-claim-btn-v1');

    let config = {
      showOverlay: true,
      closeOnOutside: true,
    };

    let active = null;
    let processing = false;

    /* ---- overlay ---- */
    function showOverlay() {
      if (config.showOverlay) overlay.classList.add('nbl-notify-active-v1');
    }
    function hideOverlay() {
      overlay.classList.remove('nbl-notify-active-v1');
    }

    overlay.addEventListener('click', () => {
      if (processing) return;
      if (!config.closeOnOutside) return;
      if (active === 'reward') closeReward();
      if (active === 'info') closeInfo();
    });

    /* closes whatever is currently open, without touching the overlay */
    function closeCurrent() {
      if (processing) return;
      if (active === 'reward') {
        rewardEl.classList.remove('nbl-notify-active-v1');
        bus.emit('notify:reward:closed');
        active = null;
      } else if (active === 'info') {
        infoEl.classList.remove('nbl-notify-active-v1');
        setClaimIdle();
        hideError();
        bus.emit('notify:info:closed');
        active = null;
      }
    }

    /* =========================
         REWARD
    ========================= */
    function openReward(code, options = {}) {
      applyOptions(options);
      closeCurrent();
      active = 'reward';
      renderReward(code);
      rewardEl.classList.add('nbl-notify-active-v1');
      showOverlay();
      bus.emit('notify:reward:opened', { code });
    }

    function closeReward() {
      if (processing) return;
      rewardEl.classList.remove('nbl-notify-active-v1');
      hideOverlay();
      active = null;
      bus.emit('notify:reward:closed');
    }

    function renderReward(code) {
      rewardWrapper.innerHTML = `
        <div class="nbl-notify-reward-code-v1">${code}</div>
        <button class="nbl-notify-reward-copy-btn-v1">Copy</button>
      `;
      rewardWrapper.querySelector('button').onclick = async () => {
        await navigator.clipboard.writeText(code);
        bus.emit('notify:reward:copied', { code });
        rewardWrapper.innerHTML = `
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span>✔ Copied</span>
            <button class="nbl-notify-reward-copy-btn-v1" style="padding:6px 12px">Close</button>
          </div>
        `;
        rewardWrapper.querySelector('button').onclick = closeReward;
      };
    }

    rewardEl.querySelector('.nbl-notify-reward-close-v1').onclick = () => closeReward();

    /* =========================
         INFO
    ========================= */
    async function openInfo({ text = '', claim = false, data = null }, options = {}) {
      applyOptions(options);
      closeCurrent();
      active = 'info';
      infoText.innerText = text;
      hideError();

      if (claim) {
        claimBtn.classList.remove('nbl-notify-hidden-v1');
        setClaimIdle();

        claimBtn.onclick = async () => {
          setClaimLoading();
          hideError();
          bus.emit('notify:info:claim:start', { data });
        };
      } else {
        claimBtn.classList.add('nbl-notify-hidden-v1');
      }

      infoEl.classList.add('nbl-notify-active-v1');
      showOverlay();
      bus.emit('notify:info:opened', { text, claim, data });
    }

    function closeInfo() {
      if (processing) return;
      infoEl.classList.remove('nbl-notify-active-v1');
      hideOverlay();
      setClaimIdle();
      hideError();
      active = null;
      bus.emit('notify:info:closed');
    }

    infoEl.querySelector('.nbl-notify-info-close-v1').onclick = () => closeInfo();

    /* ---- claim button states ---- */
    function setClaimLoading() {
      processing = true;
      claimBtn.disabled = true;
      claimBtn.innerHTML = '<span class="nbl-spinner-v1"></span><span>Processing...</span>';
    }

    function setClaimIdle() {
      processing = false;
      claimBtn.disabled = false;
      claimBtn.innerHTML = 'Claim';
    }

    /* ---- error ---- */
    function showError(message) {
      infoError.textContent = message;
      infoError.classList.add('nbl-notify-active-v1');

      setTimeout(() => hideError(), 5000);
    }

    function hideError() {
      infoError.textContent = '';
      infoError.classList.remove('nbl-notify-active-v1');
    }

    /* ---- helpers ---- */
    function applyOptions(options) {
      config = {
        showOverlay: options.showOverlay ?? true,
        closeOnOutside: options.closeOnOutside ?? true,
      };
    }

    /* remove this in production */
    function fakeApiCall() {
      return new Promise((resolve, reject) => {
        setTimeout(() => {
          const isSuccess = Math.random() > 0.5;

          if (isSuccess) {
            const data = {
              code: 'REWARD-100',
              message: 'Success',
            };
            resolve({ data });
          } else {
            reject(new Error('Coupon expired. Please try again.'));
          }
        }, 2000);
      });
    }

    // handle success claim
    function handleSuccessClaim({ response, voucher }) {
      processing = false;
      closeInfo();
      if (voucher) openReward(voucher);
    }

    // handle error claim
    function handleErrorClaim({ error }) {
      processing = false;
      const message = error?.message || 'Something went wrong. Please try again.';
      setClaimIdle();
      showError(message);
    }

    /* ---- bus bindings ---- */
    bus.on('notify:reward:open', ({ code, options } = {}) => openReward(code, options ?? {}));
    bus.on('notify:reward:close', () => closeReward());
    bus.on('notify:info:open', ({ payload, options } = {}) => openInfo(payload, options ?? {}));
    bus.on('notify:info:close', () => closeInfo());
    bus.on('notify:info:claim:success', (data) => handleSuccessClaim(data));
    bus.on('notify:info:claim:error', (data) => handleErrorClaim(data));

    return {
      openReward,
      closeReward,
      openInfo,
      closeInfo,
    };
  })();
</script>
