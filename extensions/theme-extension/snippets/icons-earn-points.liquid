{% comment %} Usage: {% render 'icon-points', icon: 'earn-points', size: 48 %} {% endcomment %}

{% assign icon_size = size | default: 50 %}

{% case icon %}
  {% when 'earn-points' %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="-60 -60 120 120">
      <circle cx="0" cy="0" r="44" fill="#85d085"/>
      <circle cx="0" cy="0" r="38" fill="none" stroke="#c9930a" stroke-width="4"/>
      <polygon fill="#c9930a" points="0,-24 6,-8 23,-8 10,2 15,18 0,9 -15,18 -10,2 -23,-8 -6,-8"/>
      <circle cx="22" cy="-22" r="14" fill="#7a8c3e"/>
      <rect x="19" y="-30" width="6" height="16" rx="2" fill="#fff"/>
      <rect x="14" y="-25" width="16" height="6" rx="2" fill="#fff"/>
    </svg>

  {% when 'purchase' %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="-60 -60 120 120">
      <rect x="-34" y="-16" width="68" height="52" rx="6" fill="#7a8c3e"/>
      <path d="M-18,-16 L-18,-26 Q0,-44 18,-26 L18,-16" fill="none" stroke="#7a8c3e" stroke-width="6" stroke-linecap="round"/>
      <rect x="-10" y="-4" width="20" height="6" rx="3" fill="#fff"/>
      <rect x="-3" y="-11" width="6" height="20" rx="3" fill="#fff"/>
    </svg>

  {% when 'referral' %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="-60 -60 120 120">
      <rect x="-34" y="0" width="68" height="40" rx="4" fill="#e05a2b"/>
      <rect x="-34" y="-14" width="68" height="16" rx="4" fill="#c0431a"/>
      <rect x="-5" y="-20" width="10" height="60" rx="3" fill="#fff" opacity="0.9"/>
      <rect x="-34" y="-6" width="68" height="10" fill="#fff" opacity="0.15"/>
      <path d="M0,-14 Q-18,-14 -18,-26 Q-18,-36 0,-28 Q18,-36 18,-26 Q18,-14 0,-14" fill="#c0431a"/>
    </svg>

  {% when 'review' %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="-60 -60 120 120">
      <rect x="-38" y="-34" width="76" height="68" rx="8" fill="#4a90d9"/>
      <polygon fill="#fff" points="0,-22 5,-8 20,-8 8,2 13,15 0,7 -13,15 -8,2 -20,-8 -5,-8"/>
      <rect x="-22" y="18" width="44" height="5" rx="2.5" fill="#fff" opacity="0.5"/>
    </svg>

  {% when 'birthday' %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="-60 -60 120 120">
      <rect x="-34" y="-4" width="68" height="42" rx="6" fill="#e879a0"/>
      <rect x="-34" y="-16" width="68" height="14" fill="#d4608c"/>
      <rect x="-22" y="-28" width="8" height="14" rx="2" fill="#f5c518"/>
      <rect x="-4" y="-28" width="8" height="14" rx="2" fill="#7a8c3e"/>
      <rect x="14" y="-28" width="8" height="14" rx="2" fill="#e05a2b"/>
      <circle cx="-18" cy="-30" r="4" fill="#ff6b6b"/>
      <circle cx="0" cy="-30" r="4" fill="#ff6b6b"/>
      <circle cx="18" cy="-30" r="4" fill="#ff6b6b"/>
      <rect x="-22" y="6" width="44" height="5" rx="2.5" fill="#fff" opacity="0.4"/>
    </svg>

  {% when 'social-share' %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="-60 -60 120 120">
      <circle cx="24" cy="-24" r="14" fill="#4a90d9"/>
      <circle cx="-24" cy="0" r="14" fill="#4a90d9"/>
      <circle cx="24" cy="24" r="14" fill="#4a90d9"/>
      <line x1="-11" y1="-4" x2="11" y2="-18" stroke="#4a90d9" stroke-width="4" stroke-linecap="round"/>
      <line x1="-11" y1="4" x2="11" y2="18" stroke="#4a90d9" stroke-width="4" stroke-linecap="round"/>
      <circle cx="24" cy="-24" r="6" fill="#fff"/>
      <circle cx="-24" cy="0" r="6" fill="#fff"/>
      <circle cx="24" cy="24" r="6" fill="#fff"/>
    </svg>

  {% when 'subscribe' %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="-60 -60 120 120">
      <circle cx="0" cy="0" r="42" fill="none" stroke="#7a8c3e" stroke-width="8" stroke-dasharray="20 8"/>
      <path d="M0,-28 L10,-14 L0,-20 L-10,-14 Z" fill="#7a8c3e"/>
      <circle cx="0" cy="0" r="14" fill="#7a8c3e"/>
      <rect x="-3" y="-8" width="6" height="16" rx="2" fill="#fff"/>
      <rect x="-8" y="-3" width="16" height="6" rx="2" fill="#fff"/>
    </svg>

  {% when 'milestone' %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="-60 -60 120 120">
      <path d="M-28,-34 L28,-34 L22,8 Q0,24 0,24 Q0,24 -22,8 Z" fill="#f5c518"/>
      <path d="M-28,-34 Q-46,-34 -46,-14 Q-46,4 -28,8 L-22,8" fill="none" stroke="#c9930a" stroke-width="6" stroke-linecap="round"/>
      <path d="M28,-34 Q46,-34 46,-14 Q46,4 28,8 L22,8" fill="none" stroke="#c9930a" stroke-width="6" stroke-linecap="round"/>
      <rect x="-10" y="24" width="20" height="10" rx="2" fill="#c9930a"/>
      <rect x="-20" y="34" width="40" height="6" rx="3" fill="#c9930a"/>
      <polygon fill="#c9930a" points="0,-24 4,-14 14,-14 6,-8 9,2 0,-4 -9,2 -6,-8 -14,-14 -4,-14"/>
    </svg>

  {% when 'complete-profile' %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="-60 -60 120 120">
      <circle cx="0" cy="-16" r="18" fill="#9b59b6"/>
      <path d="M-34,22 Q-34,-4 0,-4 Q34,-4 34,22" fill="#9b59b6"/>
      <circle cx="20" cy="16" r="16" fill="#7a8c3e"/>
      <polyline points="12,16 18,22 28,10" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

  {% when 'email-signup' %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="-60 -60 120 120">
      <rect x="-38" y="-26" width="76" height="52" rx="6" fill="#e05a2b"/>
      <polyline points="-38,-26 0,8 38,-26" fill="none" stroke="#fff" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="20" cy="16" r="16" fill="#7a8c3e"/>
      <polyline points="12,16 18,22 28,10" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

  {% when 'app-download' %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="-60 -60 120 120">
      <rect x="-22" y="-38" width="44" height="72" rx="8" fill="#374151"/>
      <rect x="-16" y="-30" width="32" height="48" rx="4" fill="#60a5fa"/>
      <circle cx="0" cy="28" r="5" fill="#9ca3af"/>
      <path d="M-6,2 L0,-10 L6,2" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
      <line x1="0" y1="2" x2="0" y2="14" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
      <line x1="-8" y1="14" x2="8" y2="14" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
    </svg>

  {% when 'first-order' %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="-60 -60 120 120">
      <path d="M-10,-38 L28,-38 L38,-28 L38,10 L0,38 L-38,10 L-38,-28 Z" fill="#f59e0b"/>
      <circle cx="-22" cy="-22" r="6" fill="#fff"/>
      <polygon fill="#fff" points="0,-8 5,6 18,6 8,14 12,28 0,20 -12,28 -8,14 -18,6 -5,6" opacity="0.9"/>
    </svg>

  {% else %}
    {% comment %} Fallback — generic star {% endcomment %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="-60 -60 120 120">
      <polygon fill="#f5c518" points="0,-44 10,-14 42,-14 18,6 28,36 0,18 -28,36 -18,6 -42,-14 -10,-14"/>
    </svg>
{% endcase %}
