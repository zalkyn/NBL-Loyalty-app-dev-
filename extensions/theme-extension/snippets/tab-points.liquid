NBL_v1.tab.renderEarnPointsList = () => {
  const container = document.querySelector('.nbl-points-list-v1');
  if (!container) return;

  const { rules = [], shop } = NBL_v1.appConfig || {};
  const currencySymbol = shop?.currencySymbol || '$';

  /* -------------------- Helpers -------------------- */

  const formatNumber = (n) => Intl.NumberFormat().format(n);

  const formatPoints = (n) =>
    `${formatNumber(n)} ${n === 1 ? 'point' : 'points'}`;

  const formatDiscount = (value, type) =>
    type === 'percentage'
      ? `${value}% off`
      : `${currencySymbol}${formatNumber(value)} off`;

  /* -------------------- Label Builder -------------------- */

  const buildLabel = (rule) => {
    const { type } = rule?.event || {};
    const { earning = {}, referral = {}, review = {} } =
      rule?.conditions || {};

    /* ===== REVIEW ===== */
    if (type === 'REVIEW') {
      const parts = [];

      if (review.text) {
        parts.push(`${formatPoints(review.text)} for text review`);
      }

      if (review.image) {
        parts.push(`${formatPoints(review.image)} for photo review`);
      }

      if (review.video) {
        parts.push(`${formatPoints(review.video)} for video review`);
      }

      return parts.join('. ');
    }

    /* ===== CREATE ORDER ===== */
    if (type === 'CREATE ORDER') {
      if (earning.type === 'incremental' && earning.rate) {
        const { points, amount } = earning.rate;
        return `Get ${formatPoints(points)} for every ${currencySymbol}${formatNumber(amount)} you spend`;
      }

      if (earning.type === 'fixed') {
        return `Get ${formatPoints(earning.fixedPoints)} for every order`;
      }
    }

    /* ===== REFERRAL ===== */
    if (type === 'REFERRAL') {
      const { referrer = {}, referred = {} } = referral;
      const parts = [];

      if (referrer.firstOrderPoints) {
        parts.push(`Get ${formatPoints(referrer.firstOrderPoints)} on first order`);
      }

      if (referrer.allowRenewalReward && referrer.renewalPoints) {
        parts.push(`Get ${formatPoints(referrer.renewalPoints)} on renewal`);
      }

      if (referred.discountValue) {
        parts.push(
          `Friend gets ${formatDiscount(
            referred.discountValue,
            referred.discountType
          )}`
        );
      }

      return parts.join('. ');
    }

    /* ===== DEFAULT ===== */
    const fallback = earning.fixedPoints ?? rule.pointsCost ?? 0;
    return `Get ${formatPoints(fallback)} for completing this action`;
  };

  /* -------------------- Points Summary -------------------- */

  const buildPointsText = (rule) => {
    const { type } = rule?.event || {};
    const { earning = {}, referral = {}, review = {} } =
      rule?.conditions || {};

    /* ===== REVIEW ===== */
    if (type === 'REVIEW') {
      const parts = [];

      if (review.text) parts.push(`${formatPoints(review.text)} text`);
      if (review.image) parts.push(`${formatPoints(review.image)} photo`);
      if (review.video) parts.push(`${formatPoints(review.video)} video`);

      return parts.join(' · ');
    }

    /* ===== REFERRAL ===== */
    if (type === 'REFERRAL') {
      const { referrer = {}, referred = {} } = referral;
      const parts = [];

      if (referrer.firstOrderPoints) {
        parts.push(`${formatPoints(referrer.firstOrderPoints)} on first order`);
      }

      // optional (you can enable if needed)
      /*
      if (referrer.allowRenewalReward && referrer.renewalPoints) {
        parts.push(`${formatPoints(referrer.renewalPoints)} on renewal`);
      }

      if (referred.discountValue) {
        parts.push(
          `Friend gets ${formatDiscount(
            referred.discountValue,
            referred.discountType
          )}`
        );
      }
      */

      return parts.join(' · ');
    }

    /* ===== CREATE ORDER ===== */
    if (type === 'CREATE ORDER') {
      if (earning.type === 'incremental' && earning.rate) {
        const { points, amount } = earning.rate;
        return `${formatPoints(points)} per ${currencySymbol}${formatNumber(amount)}`;
      }

      if (earning.type === 'fixed') {
        return `${formatPoints(earning.fixedPoints)} per order`;
      }
    }

    /* ===== DEFAULT ===== */
    const fallback = earning.fixedPoints ?? rule.pointsCost ?? 0;
    return formatPoints(fallback);
  };

  /* -------------------- Icon Mapper -------------------- */

  const getIcon = (type) => {
    switch (type) {
      case 'REVIEW':
        return `{% render 'icons-earn-points', icon: 'review' %}`;
      case 'REFERRAL':
        return `{% render 'icons-earn-points', icon: 'referral' %}`;
      case 'CREATE ORDER':
        return `{% render 'icons-earn-points', icon: 'purchase' %}`;
      default:
        return `{% render 'icons-earn-points', icon: 'earn-points' %}`;
    }
  };

  /* -------------------- Template Builder -------------------- */

  const buildItem = (rule) => {
    const { id } = rule;
    const eventType = rule?.event?.type;
    const title = rule?.event?.name || '';

    const icon = getIcon(eventType);
    const points = buildPointsText(rule);
    const label = buildLabel(rule);

    return `
      <div class="nbl-points-item-v1" data-rule-id="${id}" data-label="${label}">
        <div class="nbl-points-icon-v1">${icon}</div>

        <div class="nbl-points-content-v1">
          <div class="nbl-points-title-v1">${title}</div>
          <div class="nbl-points-points-v1">${points || '—'}</div>
        </div>

        <div class="nbl-points-action-v1">
          <button class="nbl-points-btn-v1">
            <div class="nbl-points-chevron-icon">
              {% render 'icon-chevron-right', stroke: 'rgb(66, 212, 178)' %}
            </div>
          </button>
        </div>
      </div>
    `;
  };

  /* -------------------- Render -------------------- */

  container.innerHTML = rules.map(buildItem).join('');
};


