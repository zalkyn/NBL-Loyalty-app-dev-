<div class="nbl-points-list-v1">
  <!-- rule Item -->
  <div class="nbl-points-item-v1" data-rule-id="230710">
    <!-- Icon -->
    <div class="nbl-points-icon-v1">
      {% render 'icons-earn-points', icon: 'review' %}
    </div>

    <!-- Content -->
    <div class="nbl-points-content-v1">
      <div class="nbl-points-title-v1">Voucher $5</div>

      <div class="nbl-points-points-v1">50 points</div>
    </div>

    <!-- Action -->
    <div class="nbl-points-action-v1">
      <button class="nbl-points-btn-v1" disabled>
        <div class="nbl-points-chevron-icon">{% render 'icon-chevron-right', stroke: 'rgb(66, 212, 178)' %}</div>
      </button>
    </div>
  </div>
</div>

<script>
  // Render rule list elements

  {% comment %} NBL_v1.tab.renderEarnPointsList = () => {
    const rapperEl = document.querySelector('.nbl-points-list-v1');
    if (rapperEl) {
      let listEls = '';
      NBL_v1.appConfig.rules?.map((rule, index) => {

        const eventType = rule?.event?.type || null;
        let icon = `{% render 'icons-earn-points', icon: 'earn-points' %}`;
        let points = ''

        if(eventType === 'REFERRAL') {
            icon = `{% render 'icons-earn-points', icon: 'referral' %}`;
        }
        if(eventType === 'CREATE ORDER') {
            icon = `{% render 'icons-earn-points', icon: 'purchase' %}`;
        }


        listEls += `<!-- Earn point Item -->
          <div class="nbl-points-item-v1"
            data-rule-id="${rule.id}">
            <!-- Icon -->
            <div class="nbl-points-icon-v1">
              ${icon}
            </div>

            <!-- Content -->
            <div class="nbl-points-content-v1">
              <div class="nbl-points-title-v1">${rule?.event?.name}</div>

              <div class="nbl-points-points-v1">${Intl.NumberFormat().format(rule?.pointsCost || 0)} points</div>
            </div>

            <!-- Action -->
            <div class="nbl-points-action-v1">
              <button class="nbl-points-btn-v1">
                <div class="nbl-points-chevron-icon">{% render 'icon-chevron-right', stroke: 'rgb(66, 212, 178)' %}</div>
              </button>
            </div>
          </div>`;
      });

      rapperEl.innerHTML = listEls;
    }
  }; {% endcomment %}

