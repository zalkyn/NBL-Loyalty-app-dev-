{% assign customer_config = customer.metafields.app.nbl_customer_v1.value %}
{% assign referral_link = customer_config.referralCode %}

<div class="nbl-referral-wrapper-v1">
  <div class="nbl-referral-card-v1">
    <!-- Header -->
    <div class="nbl-referral-header-v1">
      <h2 class="nbl-referral-title-v1">🎉 Invite Friends & Earn</h2>
      <p class="nbl-referral-subtitle-v1">Share your link and both of you get rewarded</p>
    </div>

    <!-- How it works -->
    <div class="nbl-referral-flow-v1">
      <div class="nbl-referral-step-v1">
        <div class="nbl-referral-icon-v1">🔗</div>
        <div class="nbl-referral-step-content-v1">
          <h4>Share your link</h4>
          <p>Send this link to your friends</p>
        </div>
      </div>

      <div class="nbl-referral-step-v1">
        <div class="nbl-referral-icon-v1">🛍️</div>
        <div class="nbl-referral-step-content-v1">
          <h4>Friend makes a purchase</h4>
          <p>They click your link and place an order</p>
        </div>
      </div>

      <div class="nbl-referral-step-v1">
        <div class="nbl-referral-icon-v1">🎁</div>
        <div class="nbl-referral-step-content-v1">
          <h4>You both get rewards</h4>
          <p>Simple and rewarding</p>
        </div>
      </div>
    </div>

    <!-- Dynamic Rewards -->
    <div class="nbl-referral-rewards-v1" id="nbl-referral-rewards"></div>

    <!-- Referral Link Only -->
    <div class="nbl-referral-section-v1">
      <label>Your Referral Link</label>
      <div class="nbl-referral-input-group-v1">
        <input
          class="nbl-referral-input-v1 nbl-referral-link-v1"
          type="text"
          value="{{ shop.url }}/?nbl-referral={{ referral_link }}"
          readonly
        >
        <button class="nbl-referral-copy-btn-v1">Copy</button>
      </div>
    </div>

    <!-- Share Buttons -->
    <div class="nbl-referral-share-v1">
      <p>Share your link</p>
      <div class="nbl-referral-share-buttons-v1">
        <button class="nbl-referral-share-btn-v1" data-share="whatsapp">📱 WhatsApp</button>
        <button class="nbl-referral-share-btn-v1" data-share="email">✉️ Email</button>
        <button class="nbl-referral-share-btn-v1" data-share="messenger">💬 Messenger</button>
        <button class="nbl-referral-share-btn-v1" data-share="sms">📩 SMS</button>
      </div>
    </div>
  </div>
</div>

<style>
  .nbl-referral-wrapper-v1 {
    display: flex;
    justify-content: center;
    padding: 10px;
  }

  .nbl-referral-card-v1 {
    width: 100%;
    max-width: 460px;
    background: #fff;
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  }

  .nbl-referral-title-v1 {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 4px 0;
    color: #1f2937;
  }

  .nbl-referral-subtitle-v1 {
    color: #6b7280;
    font-size: 14px;
    margin-bottom: 24px;
  }

  .nbl-referral-flow-v1 {
    margin-bottom: 24px;
  }

  .nbl-referral-step-v1 {
    display: flex;
    gap: 14px;
    margin-bottom: 16px;
    align-items: flex-start;
  }

  .nbl-referral-icon-v1 {
    background: #eef2ff;
    padding: 10px;
    border-radius: 12px;
    font-size: 20px;
    flex-shrink: 0;
  }

  .nbl-referral-step-content-v1 h4 {
    font-size: 15px;
    margin: 0 0 3px 0;
    font-weight: 500;
  }

  .nbl-referral-step-content-v1 p {
    font-size: 13px;
    color: #6b7280;
    margin: 0;
  }

  .nbl-referral-rewards-v1 {
    margin-bottom: 24px;
  }

  .nbl-referral-reward-card-v1 {
    display: flex;
    gap: 12px;
    background: #f8fafc;
    padding: 14px;
    border-radius: 12px;
    margin-bottom: 10px;
  }

  .nbl-referral-reward-value-v1 {
    margin: 0;
    font-size: 17px;
    font-weight: 500;
  }

  .nbl-referral-reward-note-v1 {
    font-size: 12px;
    color: #64748b;
  }

  .nbl-referral-section-v1 label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 6px;
    color: #374151;
  }

  .nbl-referral-input-group-v1 {
    display: flex;
    gap: 8px;
  }

  .nbl-referral-input-v1 {
    flex: 1;
    padding: 12px 14px;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: 15px;
    background: #f8fafc;
  }

  .nbl-referral-copy-btn-v1 {
    background: #10b981;
    color: white;
    border: none;
    padding: 0 18px;
    border-radius: 10px;
    font-weight: 500;
    cursor: pointer;
  }

  .nbl-referral-copy-btn-v1:hover {
    background: #059669;
  }

  .nbl-referral-share-v1 p {
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 10px;
  }

  .nbl-referral-share-buttons-v1 {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .nbl-referral-share-btn-v1 {
    background: #f1f5f9;
    border: none;
    padding: 9px 14px;
    border-radius: 9999px;
    font-size: 13px;
    cursor: pointer;
  }
  .nbl-referral-reward-label-v1 {
    line-height: 1;
    margin: 0 0 13px 0;
  }
</style>

<script>
  (function () {
    // Dynamic Rewards
    const rewardsContainer = document.getElementById('nbl-referral-rewards');
    const pointRules = NBL_v1?.appConfig?.pointRules || [];
    const referralRule = pointRules.find((r) => r?.event?.type === 'REFERRAL');

    if (rewardsContainer && referralRule) {
      const { referrer = {}, referred = {} } = referralRule.conditions?.referral || {};
      const trigger = referralRule.conditions?.referral?.trigger || 'oneTime';

      let html = '';

      // You Earn Section
      if (trigger === 'subscription' && referrer.allowRenewalReward && referrer.renewalPoints) {
        html += `
          <div class="nbl-referral-reward-card-v1">
            <div class="nbl-referral-reward-icon-v1">👤</div>
            <div>
              <p class="nbl-referral-reward-label-v1">You get</p>
              <h3 class="nbl-referral-reward-value-v1">${referrer.renewalPoints} Points</h3>
              <span class="nbl-referral-reward-note-v1">When friend starts subscription</span>
            </div>
          </div>`;
      } else if (referrer.firstOrderPoints) {
        html += `
          <div class="nbl-referral-reward-card-v1">
            <div class="nbl-referral-reward-icon-v1">👤</div>
            <div>
              <p class="nbl-referral-reward-label-v1">You get</p>
              <h3 class="nbl-referral-reward-value-v1">${referrer.firstOrderPoints} Points</h3>
              <span class="nbl-referral-reward-note-v1">After friend's first order</span>
            </div>
          </div>`;
      }

      // Friend Gets Section
      if (referred.discountValue) {
        const discount =
          referred.discountType === 'percentage' ? `${referred.discountValue}% off` : `$${referred.discountValue} off`;
        html += `
          <div class="nbl-referral-reward-card-v1">
            <div class="nbl-referral-reward-icon-v1">🎉</div>
            <div>
              <p class="nbl-referral-reward-label-v1">Friend gets</p>
              <h3 class="nbl-referral-reward-value-v1">${discount}</h3>
              <span class="nbl-referral-reward-note-v1">On first purchase</span>
            </div>
          </div>`;
      }

      rewardsContainer.innerHTML = html;
    }

    // Copy Link Functionality
    const linkInput = document.querySelector('.nbl-referral-link-v1');
    const copyBtn = document.querySelector('.nbl-referral-copy-btn-v1');

    if (linkInput && copyBtn) {
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(linkInput.value);
        copyBtn.textContent = 'Copied ✓';
        setTimeout(() => (copyBtn.textContent = 'Copy'), 1800);
      });
    }

    // Share Buttons
    document.querySelectorAll('.nbl-referral-share-btn-v1').forEach((btn) => {
      btn.addEventListener('click', () => {
        const text = `Use my referral link and get rewards! ${linkInput.value}`;
        const type = btn.dataset.share;

        if (type === 'whatsapp') window.open(`https://wa.me/?text=${encodeURIComponent(text)}`);
        if (type === 'email') window.open(`mailto:?subject=Join me & get rewards&body=${encodeURIComponent(text)}`);
        if (type === 'messenger')
          window.open(`https://www.facebook.com/dialog/send?link=${encodeURIComponent(linkInput.value)}`);
        if (type === 'sms') window.open(`sms:?body=${encodeURIComponent(text)}`);
      });
    });
  })();
</script>
