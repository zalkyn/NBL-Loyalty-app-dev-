{% comment %} referral modal css {% endcomment %}

<style>
  /* ================= OVERLAY ================= */
  .nbl-refer-modal-overlay-v1 {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);

    display: flex;
    align-items: center;
    justify-content: center;

    z-index: 99999;

    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;

    backdrop-filter: blur(4px);
  }

  .nbl-refer-modal-overlay-v1.show {
    opacity: 1;
    visibility: visible;
  }

  /* ================= MODAL ================= */
  .nbl-refer-modal-v1 {
    width: 620px;
    max-width: 95vw;
    max-height: 90vh;

    background: #ffffff;
    border-radius: 24px;

    position: relative;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.28);

    transform: translateY(40px) scale(0.96);
    opacity: 0;

    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);

    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* open animation */
  .nbl-refer-modal-overlay-v1.show .nbl-refer-modal-v1 {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  /* ================= CLOSE BUTTON ================= */
  .nbl-refer-modal-close-v1 {
    position: absolute;
    top: 18px;
    right: 20px;

    font-size: 32px;
    font-weight: 300;

    cursor: pointer;
    color: #6b7280;

    transition: 0.2s ease;
    z-index: 10;
  }

  .nbl-refer-modal-close-v1:hover {
    color: #111827;
    transform: rotate(90deg);
  }

  /* ================= CONTENT WRAPPER ================= */
  .nbl-refer-modal-content-v1 {
    padding: 40px 36px 36px;

    overflow-y: auto;
    flex: 1;

    scrollbar-width: thin;
    scrollbar-color: #d1d5db transparent;
  }

  /* scrollbar */
  .nbl-refer-modal-content-v1::-webkit-scrollbar {
    width: 6px;
  }

  .nbl-refer-modal-content-v1::-webkit-scrollbar-thumb {
    background: #d1d5db;
    border-radius: 20px;
  }

  .nbl-refer-modal-content-v1::-webkit-scrollbar-thumb:hover {
    background: #9ca3af;
  }

  /* ================= BRAND ================= */
  .nbl-refer-modal-brand-v1 {
    display: inline-block;

    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;

    color: #15803d;
    background: #ecfdf5;

    padding: 6px 14px;
    border-radius: 9999px;

    margin-bottom: 12px;
  }

  /* ================= TITLE ================= */
  .nbl-refer-modal-title-v1 {
    margin: 8px 0 10px;

    font-size: 26px;
    font-weight: 700;

    color: #111827;
    line-height: 1.3;
  }

  /* ================= SUBTITLE ================= */
  .nbl-refer-modal-subtitle-v1 {
    font-size: 15.5px;
    color: #4b5563;
    line-height: 1.55;
  }

  /* ================= INPUT ================= */
  .nbl-refer-modal-input-v1 {
    width: 100%;
    margin-top: 20px;

    padding: 16px 18px;

    border-radius: 14px;
    border: 1.5px solid #e5e7eb;

    background: #f9fafb;

    font-size: 15px;
    color: #111827;

    transition: all 0.2s ease;
  }

  .nbl-refer-modal-input-v1:focus {
    outline: none;
    border-color: #16a34a;

    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.15);
  }

  /* ================= BUTTON BASE ================= */
  .nbl-refer-modal-btn-v1 {
    width: 100%;
    margin-top: 22px;

    padding: 16px;

    border: none;
    border-radius: 14px;

    font-size: 15.5px;
    font-weight: 600;

    cursor: pointer;

    transition: all 0.25s ease;

    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .nbl-refer-modal-btn-v1:active {
    transform: scale(0.97);
  }

  /* ================= PRIMARY BUTTON ================= */
  .nbl-refer-modal-btn-primary-v1 {
    background: linear-gradient(135deg, #111827, #1f2937);
    color: white;
  }

  .nbl-refer-modal-btn-primary-v1:hover {
    background: linear-gradient(135deg, #1f2937, #374151);
  }

  /* ================= FINISH BUTTON ================= */
  .nbl-refer-modal-btn-finish-v1 {
    background: linear-gradient(135deg, #15803d, #22c55e);
    color: white;
    font-size: 16px;
  }

  .nbl-refer-modal-btn-finish-v1:hover {
    background: linear-gradient(135deg, #166534, #4ade80);
  }

  /* ================= CODE BOX ================= */
  .nbl-refer-modal-code-box-v1 {
    margin-top: 24px;

    padding: 24px;

    border-radius: 18px;

    background: #f8fafc;
    border: 2px dashed #d1d5db;

    text-align: center;

    transition: all 0.2s ease;
  }

  .nbl-refer-modal-code-box-v1:hover {
    border-color: #16a34a;
    background: #f0fdf4;
  }

  /* ================= CODE ================= */
  .nbl-refer-modal-code-v1 {
    font-size: 18px;
    font-weight: 800;

    letter-spacing: 2px;

    color: #111827;

    margin-bottom: 14px;

    font-family: ui-monospace, monospace;
  }

  /* ================= COPY BUTTON ================= */
  .nbl-refer-modal-copy-btn-v1 {
    padding: 10px 24px;

    border-radius: 10px;

    border: 1px solid #d1d5db;
    background: white;

    color: #374151;
    font-weight: 600;

    cursor: pointer;

    transition: all 0.25s ease;
  }

  .nbl-refer-modal-copy-btn-v1:hover {
    background: #f1f5f9;
    border-color: #16a34a;
    color: #15803d;
  }

  /* ================= COPIED TEXT ================= */
  .nbl-refer-modal-copied-text-v1 {
    margin-top: 10px;

    font-size: 13.5px;
    color: #15803d;

    font-weight: 500;
  }

  /* ================= INFO TEXT ================= */
  .nbl-refer-modal-info-text-v1 {
    margin-top: 12px;

    font-size: 13.5px;
    color: #15803d;
  }

  /* ================= MESSAGE SYSTEM (FIXED) ================= */
  .nbl-refer-modal-message-v1 {
    margin-top: 18px;

    padding: 14px 16px;

    border-radius: 12px;

    font-size: 14px;
    line-height: 1.5;

    display: none;
  }

  /* ERROR */
  .nbl-refer-modal-message-error-v1 {
    display: block;
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #b91c1c;
  }

  /* SUCCESS */
  .nbl-refer-modal-message-success-v1 {
    display: block;
    background: #f0fdf4;
    border: 1px solid #86efac;
    color: #166534;
  }

  /* INFO */
  .nbl-refer-modal-message-info-v1 {
    display: block;
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    color: #1e40af;
  }

  /* ================= IMPORTANT BOX ================= */
  .nbl-refer-modal-important-v1 {
    margin-top: 24px;

    background: #fffbeb;
    border: 1px solid #fcd34d;

    border-radius: 14px;

    padding: 16px 18px;

    font-size: 14px;
    color: #854d0e;
  }

  .nbl-refer-modal-important-v1 strong {
    display: block;
    color: #b45309;
    margin-bottom: 8px;
  }

  /* ================= LOCKED STEP ================= */
  .nbl-refer-modal-locked-v1 {
    /* same layout as other steps */
  }

  /* ================= SPINNER ================= */
  .nbl-refer-modal-spinner-v1 {
    display: inline-block;

    width: 18px;
    height: 18px;

    border: 2.5px solid rgba(255, 255, 255, 0.7);
    border-top-color: #ffffff;

    border-radius: 50%;

    animation: spin 0.75s linear infinite;

    margin-right: 10px;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* ================= HIDDEN ================= */
  .nbl-hidden-v1 {
    display: none !important;
  }

  /* ================= RESPONSIVE ================= */
  @media (max-width: 480px) {
    .nbl-refer-modal-v1 {
      border-radius: 20px;
    }

    .nbl-refer-modal-content-v1 {
      padding: 28px 22px;
    }

    .nbl-refer-modal-code-v1 {
      font-size: 15px;
    }

    .nbl-refer-modal-title-v1 {
      font-size: 22px;
    }
  }
</style>
