<div class="nbl-home-tab-v1 active" data-tab="active-reward">
  <div class="nbl-home-tab-header-v1">
    <div class="nbl-hth-heading-v1">Your active rewards</div>
    <button class="nbl-hth-toggle-btn-v1">Hide</button>
  </div>
  <div class="nbl-home-tab-body-v1">
    <div class="nbl-hta-reward-list-v1">
      <div class="nbl-hta-rewards-empty-v1">No active rewards are available</div>
    </div>
  </div>
</div>

<script>
  NBL_v1.tab.renderHomeActiveRewardList = (latestVoucher) => {
    const listWrapperEl = document.querySelector('.nbl-hta-reward-list-v1');
    if (!listWrapperEl) return;

    /* -------------------- Helpers -------------------- */

    const buildItem = ({ code, title }) => `
      <div class="nbl-hta-reward-item-v1" data-voucher="${code}">
        <div class="nbl-hta-reward-icon-v1">
          {% render 'icon-reward-discount' %}
        </div>
        <div class="nbl-hta-reward-content-v1">
          <div class="nbl-hta-reward-title-v1">${title || 'Voucher'}</div>
        </div>
        <div class="nbl-hta-reward-action-v1">
          <button class="nbl-hta-reward-btn-v1">
            <div class="nbl-hta-reward-chevron-icon">
              {% render 'icon-chevron-right', stroke: 'rgb(66, 212, 178)' %}
            </div>
          </button>
        </div>
      </div>
    `;

    const emptyState = `<div class="nbl-hta-rewards-empty-v1">No active rewards are available</div>`;

    /* -------------------- Filter rewards -------------------- */

    const activeRewards = (NBL_v1.customer.config.rewards || []).filter(
      (r) => r.discountUsed === false && r.status === 'ACTIVE'
    );

    /* -------------------- Append latestVoucher if not duplicate -------------------- */

    const existingCodes = new Set(activeRewards.map((r) => r.code));

    if (latestVoucher?.code && !existingCodes.has(latestVoucher.code)) {
      activeRewards.push({
        code: latestVoucher.code,
        title: latestVoucher.title || 'Voucher',
      });
    }

    /* -------------------- Render -------------------- */

    listWrapperEl.innerHTML = activeRewards.length ? activeRewards.map(buildItem).join('') : emptyState;
  };

  /* -------------------- Event listeners -------------------- */

  NBL_v1.bus.on('dom:loaded', () => {
    NBL_v1.tab.renderHomeActiveRewardList();
  });

  NBL_v1.bus.on('notify:info:claim:success', ({ response, voucher }) => {
    if (voucher?.length > 5) {
      NBL_v1.tab.renderHomeActiveRewardList({
        code: voucher,
        title: response?.title || 'Voucher',
      });
    }
  });
</script>
